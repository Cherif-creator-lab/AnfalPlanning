# Port du serveur de l'application locale (par défaut: 3000)
PORT=3000

# Token secret choisi pour la validation de sécurité du webhook Meta
# Renseignez ce même token dans votre console Meta Developer lors de la configuration du Webhook
WA_VERIFY_TOKEN="token_secret_planning"

# ID de numéro de téléphone WhatsApp (Phone Number ID de la sandbox ou du numéro réel)
# Disponible sur la console Meta : Tableau de bord -> WhatsApp -> Configuration de départ
WA_PHONE_NUMBER_ID=""

# Token d'accès permanent généré via le gestionnaire de comptes Meta Business
# IMPORTANT : Le token d'accès temporaire expire après 24 heures. Générez un token permanent en production.
WA_ACCESS_TOKEN=""

# Numéro de téléphone de Samira (avec préfixe international, ex: +33612345678)
WA_RECIPIENT_PHONE_NUMBER=""
